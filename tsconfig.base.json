{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@mes-system/shared-types": ["./libs/shared-types/src/index.ts"],
      "@mes-system/database": ["./libs/database/src/index.ts"],
      "@mes-system/inventory": ["./libs/inventory/src/index.ts"],
      "@mes-system/server-auth": ["./libs/server-auth/src/index.ts"],
      "@mes-system/grpc-schemas": ["./libs/grpc-schemas/src/index.ts"],
      "@mes-system/message-bus": ["./libs/message-bus/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
